# LLM Configuration
LLM_API_URL=http://localhost:8081
LLM_MODEL_NAME=Qwen3.6-35B-A3B-UD-Q5_K_M.gguf
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# PostgreSQL + pgvector
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=openclaw
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=openclaw123

# Sandbox
SANDBOX_TIMEOUT=30
SANDBOX_CPU_LIMIT=1
SANDBOX_MEMORY_LIMIT=512
SANDBOX_NETWORK_ENABLED=false

# RAG
RAG_K=10
RERANK_THRESHOLD=0.5
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Embedding / Reranker
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base

# API
API_HOST=0.0.0.0
API_PORT=8000
MAX_RETRIES=3
